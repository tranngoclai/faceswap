#!/usr/bin/env bash
# Managed by Ansible (roles/faceswap_cloudsync). Do not edit by hand.
# rclone gdrive remote is pre-configured by the cloudsync role using the
# OAuth token from Ansible vault (rp_gdrive_token_json → /root/.config/rclone/rclone.conf).
export HOME=/root
export PATH=/venv/main/bin:/usr/local/bin:/usr/bin:/bin
ts="$(date '+%F %T')"
out="$(rclone copy {{ cc_sync_src }} {{ cc_sync_dst }} --transfers 4 2>&1)"
echo "[$ts] $out" >> /root/cloud-sync.log
