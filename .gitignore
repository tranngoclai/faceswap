# Global (Exclude all + retain files that are unlikely to pollute local installs)
*
!*.keep
!*.md

# Requirements files
!/requirements/
!/requirements/*requirements*.txt
!/requirements/*conda*.yml
!/requirements/*.py

# Root files
!pyproject.toml
!.gitignore
!.travis.yml
!Makefile
!/faceswap.py
!/setup.py
!/tools.py
!/update_deps.py

# Cloud training + extract/convert: migrated to Ansible (ansible/).
!/ansible/
!/ansible/**

# Support files
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml
!.install/
!.install/**
!config/
!.readthedocs.yml
!.dockerignore
!/docker/
!/docker/**/
!/docker/**/*.dockerfile
!/docker/**/Dockerfile
!docs/
!docs/_static/
!docs/_static/*.png
!docs/full/
!docs/full/**/
!docs/full/**/*.rst
!locales/
!locales/**

# Test files
!tests/
!tests/**/
!tests/**/*.py
!tests/**/*.mp4
!tests/**/*.jpg

# Core files
!.fs_cache
!lib/
!lib/**/
!lib/**/*.py
!lib/gui/**/icons/*.png
!lib/gui/**/themes/default.json
!lib/gui/**/presets/**/*.json
!plugins/
!plugins/**/
!plugins/**/*.py
!scripts/
!scripts/*.py
!scripts/**/
!scripts/**/*.py
!tools/
!tools/**/
!tools/**/*.py

# GUI Plugin Presets
!lib/gui/**/presets/train/model_phaze_a_dfaker_preset.json
!lib/gui/**/presets/train/model_phaze_a_dfl-h128_preset.json
!lib/gui/**/presets/train/model_phaze_a_dfl-sae-df_preset.json
!lib/gui/**/presets/train/model_phaze_a_dfl-sae-liae_preset.json
!lib/gui/**/presets/train/model_phaze_a_dfl-saehd-df_preset.json
!lib/gui/**/presets/train/model_phaze_a_dfl-saehd-liae_preset.json
!lib/gui/**/presets/train/model_phaze_a_iae_preset.json
!lib/gui/**/presets/train/model_phaze_a_lightweight_preset.json
!lib/gui/**/presets/train/model_phaze_a_original_preset.json
!lib/gui/**/presets/train/model_phaze_a_stojo_preset.json

# App env
app/.env

# App
!app/
!app/main.py
!app/manifest.py
!app/rclone_runtime.py
!app/.env.example
!app/requirements.txt
!app/Dockerfile

# App env
app/.env

# Terraform
!/terraform/
!/terraform/*.tf
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfplan
