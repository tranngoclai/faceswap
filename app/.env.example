# RunPod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_API_BASE=https://api.runpod.ai/v2

# Google Drive
# Local dev: run `make gdrive-setup` — token stored in ~/.config/rclone/rclone.conf, no env var needed.
# Docker / RunPod workers: set GDRIVE_TOKEN_JSON (run `make vault-sync` to push to Ansible vault).
GDRIVE_TOKEN_JSON=
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_REMOTE=gdrive
